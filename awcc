#!/usr/bin/env python3
"""awcc — launcher for the AWCC-Linux GTK GUI."""

import os
import sys

# Work around a compositor damage artifact (stray pixel by group titles that
# clears on resize; see awcc_gui/app.py): software renderer + forced full
# redraws. Set here too, before anything imports GTK; respect user overrides.
os.environ.setdefault("GSK_RENDERER", "cairo")
os.environ.setdefault("GSK_DEBUG", "full-redraw")

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from awcc_gui.app import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main())
