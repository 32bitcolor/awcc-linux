#!/usr/bin/env python3
"""awcc — launcher for the AWCC-Linux GTK GUI."""

import os
import sys

# Use the software renderer by default (avoids an intermittent GTK4 GPU-renderer
# damage artifact; see awcc_gui/app.py). Set here too, before anything imports
# GTK, and only if the user hasn't chosen a renderer.
os.environ.setdefault("GSK_RENDERER", "cairo")

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from awcc_gui.app import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main())
